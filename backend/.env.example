# ========== Server ==========
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ========== Market data (for src/index.js) ==========
TWELVE_DATA_API_KEY=your_twelvedata_api_key
# Quote poll interval (ms) when not using WebSocket – default 3000. Use 2000 for faster ticker; max 30000.
# QUOTE_POLL_INTERVAL_MS=3000
# Twelve Data WebSocket: set to 'true' for market-grade real-time streaming (faster than REST polling)
TWELVE_DATA_WS=true
# Market data log: set to 'false' to disable. Log file: backend/logs/market-data.log
# MARKET_DATA_LOG=true

# ========== MongoDB (required for trading, finance, auth) ==========
# Copy to .env and set one of:
#   Local:  CONNECTION_STRING=mongodb://localhost:27017/fxmark
#   Atlas:  CONNECTION_STRING=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=ClusterName
# Verify:  npm run check-mongo
CONNECTION_STRING=mongodb://localhost:27017/fxmark

# ========== Auth (JWT) ==========
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRY=7d

# ========== Email (Gmail) — verification & notifications ==========
# Used for: (1) Email verification on signup + resend, (2) Support/notification emails.
# Use a Gmail account with "App Password" (Google Account → Security → 2-Step Verification → App passwords).
# App password: 16 characters, no spaces (spaces are stripped automatically if present).
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
# API_URL (above) must be your backend base URL so verification links in emails work (e.g. http://localhost:3000 or https://api.yourdomain.com).
# Optional: display name and from address (defaults to GMAIL_USER)
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=FXMARK

# ========== Optional: PostgreSQL (if used for ledger/finance) ==========
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fxmark
# DB_USER=postgres
# DB_PASSWORD=

# ========== Bulk user import (admin) ==========
# Default main and investor passwords for all imported users (hashed before save). If unset, fallbacks are used.
# BULK_IMPORT_DEFAULT_PASSWORD=ImportMain1!
# BULK_IMPORT_DEFAULT_INVESTOR_PASSWORD=ImportInvestor1!
# Imported users are created with emailVerified=true so they can log in without verifying email.

# ========== Optional: Redis (faster cache for candles / market data) ==========
# Use REDIS_URL or REDIS_HOST. When set, cache uses Redis; otherwise in-memory.
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_PREFIX=fxmark:

# ========== Daily wallet vs ledger reconciliation (read-only) ==========
# RECONCILIATION_CRON_DISABLED=1
# RECONCILIATION_DAILY_HOUR_UTC=3
# RECONCILIATION_TOLERANCE=0.01
# RECONCILIATION_TOP_MISMATCHES_LOG=20

# PAMM: reclaim stuck "processing" only if heartbeat older than this (ms). Active workers refresh heartbeat every ~10–30s.
# PAMM_DISTRIBUTION_STALE_MS=600000
# PAMM: heartbeat interval clamp (ms), default 20000; also pulses every 5 users.
# PAMM_DIST_HEARTBEAT_MS=20000

# ========== Fraud detection (withdrawal) ==========
# FRAUD_WINDOW_MINUTES=15
# FRAUD_MAX_WITHDRAWALS_IN_WINDOW=5
# FRAUD_HIGH_AMOUNT=10000
# FRAUD_RAPID_MINUTES=5
# FRAUD_NEW_USER_DAYS=7
# FRAUD_NEW_USER_HIGH_AMOUNT=1000
