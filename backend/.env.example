# Copy to `backend/.env`. The Node API loads only `backend/.env` via `config/load-env.js` (no `.env` at the monorepo root).
# Quick check: npm run check:zoho
#
# ========== Server ==========
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
# Public web app URL (no trailing slash). Production: https://fxmarktrade.com
# Local: use http://localhost:5173. If NODE_ENV=production but API_URL is still http://localhost:3000, the server
# defaults FRONTEND_URL to localhost:5173 when this is unset (GET /api/auth/login redirect, verify-email redirect).
FRONTEND_URL=http://localhost:5173
# Optional: email verification token lifetime in ms (default 3600000 = 1 hour)
# EMAIL_VERIFICATION_EXPIRY_MS=3600000
# Password reset link lifetime in ms (default 3600000 = 1 hour; must match expiry text in forgot-password email)
# PASSWORD_RESET_EXPIRY_MS=3600000

# ========== Security (optional) ==========
# Comma-separated origins for CORS (e.g. https://app.example.com,https://admin.example.com). If unset, all origins allowed.
# ALLOWED_ORIGINS=https://app.example.com
# Global rate limit: max requests per 15 min per IP (default 200).
# RATE_LIMIT_MAX_GLOBAL=200
# Auth rate limit: only POST /api/auth/login, /api/auth/register, /api/auth/signup (not verify-email or resend).
# Default max 10/15min per IP in production; higher when API_URL is localhost or NODE_ENV=development.
# Loopback + OPTIONS skip counting. RATE_LIMIT_SKIP_AUTH=true skips auth limiter entirely (dev only).
# RATE_LIMIT_MAX_AUTH=200

# ========== Market data (for src/index.js) ==========
TWELVE_DATA_API_KEY=your_twelvedata_api_key
# Quote poll interval (ms) when not using WebSocket – default 3000. Use 2000 for faster ticker; max 30000.
# QUOTE_POLL_INTERVAL_MS=3000
# Twelve Data WebSocket: set to 'true' for market-grade real-time streaming (faster than REST polling)
TWELVE_DATA_WS=true
# Market data log: set to 'false' to disable. Log file: backend/logs/market-data.log
# MARKET_DATA_LOG=true
# Finnhub WebSocket (gold/XAU etc.): https://finnhub.io — used when FINNHUB_API_KEY is set
# FINNHUB_API_KEY=your_finnhub_api_key

# ========== MongoDB (required for trading, finance, auth) ==========
# Copy to .env and set one of:
#   Local:  CONNECTION_STRING=mongodb://localhost:27017/fxmark
#   Atlas:  CONNECTION_STRING=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=ClusterName
# Verify:  npm run check-mongo
CONNECTION_STRING=mongodb://localhost:27017/fxmark

# ========== Auth (JWT) ==========
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRY=7d

# ========== Email (Zoho Mail) — verification & notifications ==========
# Zoho Mail → use mailbox SMTP: smtp.zoho.com:465 (default) or smtp.zoho.eu / smtp.zoho.in by region.
# With 2FA, use an App Password in ZOHO_MAIL_PASSWORD. Spaces in password are stripped in app.
# Test: node scripts/test-email.js your-inbox@example.com
ZOHO_MAIL_USER=noreply@yourdomain.com
ZOHO_MAIL_PASSWORD=your_zoho_password_or_app_password
# GCP production: Secret Manager — see DEPLOY.md and scripts/fix-zoho-secrets.ps1
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465
# API_URL (above) must be your backend base URL; FRONTEND_URL must be your public web app for verification links.
# FROM_EMAIL: use same as ZOHO_MAIL_USER (or a Zoho-approved alias) so mail is less likely to land in spam.
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=FXMARK
#
# Welcome email footer (signup) — optional; defaults FROM_NAME / FRONTEND_URL / support email from above
# MAIL_COMPANY_NAME=FXMARK
# MAIL_COMPANY_LEGAL=FXMARK Ltd
# MAIL_SUPPORT_EMAIL=support@yourdomain.com
# MAIL_SUPPORT_PHONE=+1 234 567 8900
# MAIL_COMPANY_WEBSITE=https://fxmarktrade.com
# MAIL_COMPANY_ADDRESS=123 Trading Street\nCity, Country
# Welcome email logo (default: FRONTEND_URL/fxmark-logo.png — ensure file exists in frontend public/)
# MAIL_LOGO_URL=https://fxmarktrade.com/fxmark-logo.png

# ========== Optional: PostgreSQL (if used for ledger/finance) ==========
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fxmark
# DB_USER=postgres
# DB_PASSWORD=

# ========== Bulk user import (admin) ==========
# Default main and investor passwords for all imported users (hashed before save). If unset, fallbacks are used.
# BULK_IMPORT_DEFAULT_PASSWORD=ImportMain1!
# BULK_IMPORT_DEFAULT_INVESTOR_PASSWORD=ImportInvestor1!
# Imported users are created with emailVerified=true so they can log in without verifying email.

# ========== Optional: Redis (faster cache for candles / market data) ==========
# Use REDIS_URL or REDIS_HOST. When set, cache uses Redis; otherwise in-memory.
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_PREFIX=fxmark:

# ========== Daily wallet vs ledger reconciliation (read-only) ==========
# RECONCILIATION_CRON_DISABLED=1
# RECONCILIATION_DAILY_HOUR_UTC=3
# RECONCILIATION_TOLERANCE=0.01
# RECONCILIATION_TOP_MISMATCHES_LOG=20

# FINANCE_AUTO_RECONCILE_WALLET removed — drift is log-only (see verifyWalletLedgerAfterMutation).
# On startup, create WALLET ledger unique index if DB has no duplicate business keys.
# FINANCE_ENSURE_WALLET_LEDGER_INDEX=1

# PAMM: reclaim stuck "processing" only if heartbeat older than this (ms). Active workers refresh heartbeat every ~10–30s.
# PAMM_DISTRIBUTION_STALE_MS=600000
# PAMM: heartbeat interval clamp (ms), default 20000; also pulses every 5 users.
# PAMM_DIST_HEARTBEAT_MS=20000

# ========== Fraud detection (withdrawal) ==========
# FRAUD_WINDOW_MINUTES=15
# FRAUD_MAX_WITHDRAWALS_IN_WINDOW=5
# FRAUD_HIGH_AMOUNT=10000
# FRAUD_RAPID_MINUTES=5
# FRAUD_NEW_USER_DAYS=7
# FRAUD_NEW_USER_HIGH_AMOUNT=1000
