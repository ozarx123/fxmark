# Copy to `backend/.env`. The Node API loads only `backend/.env` via `config/load-env.js` (no `.env` at the monorepo root).
# Quick check: npm run check:zoho
#
# Optional: Super Admin → Admin → Environment — store overrides in MongoDB (settings.platform_env_overrides).
# They apply after Mongo connects and override same-named variables from this file. See backend/docs/PLATFORM_ENV_MANAGER.md
#
# ========== Server ==========
NODE_ENV=development
# Local development: API listens on this port (match frontend-web Vite proxy + VITE_API_URL).
PORT=3000
API_URL=http://localhost:3000
# Public web app URL (no trailing slash). Production: https://fxmarktrade.com
# Local: use http://localhost:5173. If NODE_ENV=production but API_URL is still http://localhost:3000, the server
# defaults FRONTEND_URL to localhost:5173 when this is unset (GET /api/auth/login redirect, verify-email redirect).
#
# Email verification: links prefer FRONTEND_URL/verify-email?token=… If FRONTEND_URL is unset but API_URL is a
# public HTTPS URL, verification emails use GET /api/auth/verify-email?token=… on the API (in-browser verify).
# Set FRONTEND_URL in production so users land in the SPA; keep API_URL correct and externally reachable.
FRONTEND_URL=http://localhost:5173
# Optional: email verification token lifetime in ms (default 3600000 = 1 hour)
# EMAIL_VERIFICATION_EXPIRY_MS=3600000
# Set to false to disable verification (login allowed without verified email; new signups are created verified). Default true.
# EMAIL_VERIFICATION_REQUIRED=false
# Password reset link lifetime in ms (default 3600000 = 1 hour; must match expiry text in forgot-password email)
# PASSWORD_RESET_EXPIRY_MS=3600000

# ========== Security ==========
# Comma-separated origins for CORS + Socket.IO (must match the browser origin, no trailing path).
# Required when NODE_ENV=production and API_URL is NOT localhost (process exits on boot if missing).
# If unset in development, CORS allows all origins (not for public production).
# ALLOWED_ORIGINS=https://app.example.com,https://www.app.example.com
#
# Behind Render/nginx: trust one proxy hop so req.ip and rate limits use the real client (default on public prod).
# TRUST_PROXY=true
#
# Optional TOTP (base32) for all /api/admin/* requests. Generate e.g. with: node -e "console.log(require('crypto').randomBytes(20).toString('base64'))"
# then store base32 secret from your authenticator app's "manual entry" format, or use otplib docs.
# When set, send current code in header X-Admin-Mfa (Admin UI has a field at top of /admin).
# ADMIN_MFA_TOTP_SECRET=
#
# Global rate limit: max requests per 15 min per IP (default 200).
# RATE_LIMIT_MAX_GLOBAL=200
# Auth rate limit: only POST /api/auth/login, /api/auth/register, /api/auth/signup (not verify-email or resend).
# Default max 10/15min per IP in production; higher when API_URL is localhost or NODE_ENV=development.
# Loopback + OPTIONS skip counting. RATE_LIMIT_SKIP_AUTH=true skips auth limiter entirely (dev only; forbidden on public prod).
# RATE_LIMIT_MAX_AUTH=200

# ========== Market data (for src/index.js) ==========
# Twelve Data (primary WebSocket ticks when key set; Finnhub is fallback) — https://twelvedata.com
# TWELVEDATA_API_KEY and TWELVE_DATA_API_KEY are both accepted (same value).
# TWELVE_DATA_WS=false disables the Twelve Data WebSocket only (Finnhub remains).
TWELVEDATA_API_KEY=YOUR_KEY_HERE
# TWELVE_DATA_API_KEY=YOUR_KEY_HERE
# TWELVE_DATA_WS=true
# Finnhub: candles, quotes, WebSocket ticks — https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key
# Quote poll interval (ms) for REST fallback when WS is down — default 3000. Max 30000.
# QUOTE_POLL_INTERVAL_MS=3000
# Market tick log: set to 'false' to disable. File: backend/logs/market-data.log
# MARKET_DATA_LOG=true
# Provider feed log (ticks/poller/errors): set to 'false' to disable. File: backend/logs/market-feed.log
# MARKET_FEED_LOG=true
# Max OHLC bars returned by GET /api/market/candles (default 1500; caps Twelve/Finnhub before JSON + cache).
# MAX_CHART_CANDLES=1500

# ========== MongoDB (required for trading, finance, auth) ==========
# Copy to .env and set one of:
#   Local:  CONNECTION_STRING=mongodb://localhost:27017/fxmark
#   Atlas (development/staging): put the staging DB name in the URI path (not bare /test):
#          ...mongodb.net/test_staging_20260331104711?retryWrites=true&w=majority
#   If the URI has no path before ?, MongoDB defaults to database "test" — avoid that for staging work.
# Verify:  npm run check-mongo
CONNECTION_STRING=mongodb://localhost:27017/fxmark
# DB guardrails (see config/mongo.js):
# - production (NODE_ENV=production): URI path must equal REQUIRED_PROD_DB_NAME (default: test)
# - development/staging: URI path must equal REQUIRED_NON_PROD_DB_NAME (staging DB name below)
# - local runtime (API_URL/FRONTEND_URL on localhost) cannot use REQUIRED_PROD_DB_NAME (blocks accidental prod)
# REQUIRED_PROD_DB_NAME=test
# REQUIRED_NON_PROD_DB_NAME=test_staging_20260331104711

# ========== Auth (JWT) ==========
# Production: must be random, >= 32 characters (not "change-me"); server refuses to start otherwise.
JWT_SECRET=your_jwt_secret_min_32_characters_long
# Access token lifetime. Public production (non-local API_URL) defaults to 15m in code if unset — use refresh token for longer sessions.
JWT_EXPIRY=7d
# Refresh token lifetime (rotation on each POST /api/auth/refresh).
# JWT_REFRESH_EXPIRY=30d

# ========== Email (Zoho Mail) — verification & notifications ==========
# Zoho Mail → use mailbox SMTP: smtp.zoho.com:465 (default) or smtp.zoho.eu / smtp.zoho.in by region.
# With 2FA, use an App Password in ZOHO_MAIL_PASSWORD. Spaces in password are stripped in app.
# Test: node scripts/test-email.js your-inbox@example.com
ZOHO_MAIL_USER=noreply@yourdomain.com
ZOHO_MAIL_PASSWORD=your_zoho_password_or_app_password
# GCP production: Secret Manager — see DEPLOY.md and scripts/fix-zoho-secrets.ps1
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465
# API_URL (above) must be your backend base URL; FRONTEND_URL must be your public web app for verification links.
# FROM_EMAIL: use same as ZOHO_MAIL_USER (or a Zoho-approved alias) so mail is less likely to land in spam.
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=FXMARK
#
# Welcome email footer (signup) — optional; defaults FROM_NAME / FRONTEND_URL / support email from above
# MAIL_COMPANY_NAME=FXMARK
# MAIL_COMPANY_LEGAL=FXMARK Ltd
# MAIL_SUPPORT_EMAIL=support@yourdomain.com
# MAIL_SUPPORT_PHONE=+1 234 567 8900
# MAIL_COMPANY_WEBSITE=https://fxmarktrade.com
# MAIL_COMPANY_ADDRESS=123 Trading Street\nCity, Country
# Welcome email logo (default: FRONTEND_URL/fxmark-logo.png — ensure file exists in frontend public/)
# MAIL_LOGO_URL=https://fxmarktrade.com/fxmark-logo.png

# Wallet balance emails (deposit, withdrawal, transfer, trade P&L, admin credit, etc.)
# Default: enabled. Set to 0 to disable.
# MAIL_WALLET_BALANCE_UPDATES=0
# Comma-separated wallet_transactions.type values to skip (default excludes bulk import rows)
# MAIL_WALLET_BALANCE_EXCLUDE_TYPES=import_opening_balance
# Skip tiny amounts for non-deposit/withdrawal/transfer types (USD)
# MAIL_WALLET_NOTIFY_MIN_ABS=0.005
# Verify wiring (no email sent): npm run check:wallet-email-integration
# With API running: node scripts/integration-wallet-email-check.js --health

# Wallet deposits (PSP): default in DB is off until Admin enables payment settings.
# Set to true or 1 to allow deposits without Mongo admin config — forces PSP on and enables card + bank_transfer
# when no method is enabled in DB (local/demo only; do not use on public production without a real payment provider).
# PAYMENT_PSP_ENABLED=true

# ========== NOWPayments (USDT BEP20 — normal Payment API + IPN + Mass Payout; not Custody) ==========
# Enable the integration and create payments (x-api-key from dashboard).
# NOWPAYMENTS_ENABLED=true
# NOWPAYMENTS_API_KEY=
# IPN signing secret from NOWPayments dashboard (Instant Payment Notifications).
# NOWPAYMENTS_IPN_SECRET=
# Public API base URL used to build ipn_callback_url (no trailing slash). Defaults to API_URL if unset.
# NOWPAYMENTS_IPN_BASE_URL=https://api.yourdomain.com
# Fixed pay currency for deposits and payouts (USDT on BSC / BEP20).
# NOWPAYMENTS_PAY_CURRENCY=usdtbsc
# Optional webhook source IP allowlist (comma-separated). Leave empty to disable.
# NOWPAYMENTS_IP_ALLOWLIST=1.2.3.4,5.6.7.8
# Payment expiry window in minutes (clamped to 15..30).
# NOWPAYMENTS_PAYMENT_EXPIRY_MINUTES=30
# Optional override; default https://api.nowpayments.io/v1
# NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1
# Mass Payout API: same dashboard account email/password (Bearer token for POST /v1/payout).
# NOWPAYMENTS_ACCOUNT_EMAIL=
# NOWPAYMENTS_ACCOUNT_PASSWORD=
# Admin: POST /api/admin/withdrawals/:id/nowpayments-payout (Super Admin). User: POST /api/wallet/deposits/nowpayments
# Webhook: POST /api/webhooks/nowpayments (header x-nowpayments-sig)

# ========== Optional: PostgreSQL (if used for ledger/finance) ==========
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fxmark
# DB_USER=postgres
# DB_PASSWORD=

# ========== Bulk user import (admin) ==========
# Default main and investor passwords for all imported users (hashed before save). If unset, fallbacks are used.
# BULK_IMPORT_DEFAULT_PASSWORD=ImportMain1!
# BULK_IMPORT_DEFAULT_INVESTOR_PASSWORD=ImportInvestor1!
# Imported users are created with emailVerified=true so they can log in without verifying email.

# ========== Optional: Redis (faster cache for candles / market data) ==========
# Use REDIS_URL or REDIS_HOST. When set, cache uses Redis; otherwise in-memory.
# Also used for access-token revocation on logout (recommended in multi-instance production).
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_PREFIX=fxmark:

# ========== Daily wallet vs ledger reconciliation (read-only) ==========
# RECONCILIATION_CRON_DISABLED=1
# RECONCILIATION_DAILY_HOUR_UTC=3
# RECONCILIATION_TOLERANCE=0.01
# RECONCILIATION_TOP_MISMATCHES_LOG=20

# FINANCE_AUTO_RECONCILE_WALLET removed — drift is log-only (see verifyWalletLedgerAfterMutation).
# On startup, create WALLET ledger unique index if DB has no duplicate business keys.
# FINANCE_ENSURE_WALLET_LEDGER_INDEX=1
#
# Super Admin profit/commission: negative wallet adjustment normally requires balance ≥ debit. Set to allow debit anyway (negative balance risk).
# ADMIN_PROFIT_ADJUST_ALLOW_INSUFFICIENT_BALANCE=1

# PAMM: reclaim stuck "processing" only if heartbeat older than this (ms). Active workers refresh heartbeat every ~10–30s.
# PAMM_DISTRIBUTION_STALE_MS=600000
# PAMM: heartbeat interval clamp (ms), default 20000; also pulses every 5 users.
# PAMM_DIST_HEARTBEAT_MS=20000

# ========== Trading: margin / tick risk (beyond TP/SL) ==========
# Same marks as GET /trading/account-summary (equity = balance + floating PnL; marginLevel = equity/marginUsed*100).
#
# Order on each tick (per account touched by that symbol): (1) TP/SL, (2) zero-equity close (always on),
# (3) margin stop-out if MARGIN_LEVEL_STOP_OUT_BELOW_PCT > 0, (4) margin warning if warn enabled and account
# was not fully closed this tick. Warnings are throttled per account (MARGIN_LEVEL_WARN_INTERVAL_MS).
#
# Recommended pairs (WARN = emit risk_event only; STOP = hard close all positions). Use WARN > STOP so
# clients get alerts before liquidation. Both optional; defaults = disabled (0 / unset).
#
#   Profile          WARN_BELOW_PCT   STOP_OUT_BELOW_PCT   Notes
#   ---------------  ---------------  -------------------  ----------------------------------------
#   Off (default)    (unset/0)        (unset/0)            Only zero-equity + TP/SL
#   Conservative     200              80                 Early heads-up; stop before deep drawdown
#   Typical retail     150             100                 “Call” feel near 100%; stop at/below 100%
#   Tighter            120              50                 More room after warning; hard stop at 50%
#   Aggressive       (unset/0)          30                 No server warning; late stop-out only
#
# MARGIN_LEVEL_STOP_OUT_BELOW_PCT=0
# MARGIN_LEVEL_WARN_BELOW_PCT=0
# MARGIN_LEVEL_WARN_INTERVAL_MS=120000

# ========== IB: default introducing broker (direct signups) ==========
# When a user registers without ?ref=, the server may set users.referrerId to this user id if they have ib_profiles.
# Prefer storing the default in Admin → IB & commission (persists in Mongo ib_settings). This env is a fallback when DB has no value.
# Must match a real users._id string that has an IB profile; otherwise registration logs a warning and leaves referrer unset.
# DEFAULT_IB_REFERRER_USER_ID=

# ========== Feature flags (safe rollout) ==========
# Optional force override for PAMM global kill switch.
# When set, this env value overrides DB feature flags.
# FEATURE_PAMM_GLOBAL_KILL_SWITCH=false

# ========== Fraud detection (withdrawal) ==========
# FRAUD_WINDOW_MINUTES=15
# FRAUD_MAX_WITHDRAWALS_IN_WINDOW=5
# FRAUD_HIGH_AMOUNT=10000
# FRAUD_RAPID_MINUTES=5
# FRAUD_NEW_USER_DAYS=7
# FRAUD_NEW_USER_HIGH_AMOUNT=1000
