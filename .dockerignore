# Dependencies
node_modules/
**/node_modules/

# Env and secrets (never ship to image)
.env
.env.*
!.env.example

# Build outputs
dist/
build/
**/dist/
**/build/

# Git and IDE
.git/
.gitignore
.cursor/
.vscode/
*.swp
*.swo

# Docs and non-runtime
docs/
*.md
!backend/README.md

# Logs and temp
*.log
**/logs/
tmp/
temp/

# Test and dev
**/__tests__/
**/*.test.js
**/*.spec.js
coverage/
.nyc_output/

# Other project parts (backend-only image)
frontend-web/
frontend-admin/
mobile-flutter/
# Keep docker/Dockerfile.backend.prod in context for Cloud Build (do not ignore whole docker/)
docker/*.ps1
docker/*.sh

# Dev / pentest / stress scripts — not needed at runtime in Cloud Run
backend/scripts/

# Archives
*.zip
*.pdf
*.docx
