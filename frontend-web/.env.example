# Copy to `.env.local` for local overrides (gitignored).
# Development defaults (port 3000 backend): see `.env.development`.
#
# API URL — if unset during `npm run dev`, the app uses `/api` (Vite proxies to http://localhost:3000).
# Set this ONLY when you need the browser to call a specific backend (e.g. Cloud Run) from local dev.
#
# Leave commented for normal local dev (same machine as `cd backend && npm run dev`):
# VITE_API_URL=http://localhost:3000/api
#
# If you set the deployed API here while testing locally, email resend uses THAT server’s env —
# not your local backend/.env (Zoho must be configured on Cloud Run too).
# VITE_API_URL=https://your-backend.example.com/api
